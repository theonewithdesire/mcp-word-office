{
    "mcpServers": {
        "blender": {
            "command": "uvx",
            "args": [
                "blender-mcp"
            ]
        },
        "word-office": {
            "command": "python3",
            "args": [
                "word_mcp_server_mac.py"
            ],
            "env": {},
            "disabled": false,
            "autoApprove": [
                "create_document",
                "insert_text",
                "format_text",
                "save_document",
                "read_document",
                "create_table",
                "create_list",
                "add_heading",
                "list_documents"
            ]
        }
    }
}